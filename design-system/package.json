{
  "name": "@tuvsud/design-system",
  "version": "1.19.2",
  "release": true,
  "description": "TÜV SÜD Algorithm Design System",
  "license": "MIT",
  "author": {
    "name": "Feras Ahmad",
    "email": "feras.ahmad@tuvsud.com"
  },
  "repository": {
    "url": "https://dev.azure.com/tuvsud01/ALGORITHM%20Design%20System/_git/design-system"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/entry.js",
      "types": "./dist/entry.d.ts"
    },
    "./*": {
      "import": "./dist/components/*/index.js",
      "types": "./dist/components/*/index.d.ts"
    },
    "./react": {
      "import": "./dist/entry-react.js",
      "types": "./dist/entry-react.d.ts"
    },
    "./react/*": {
      "import": "./dist/components/*/react/index.js",
      "types": "./dist/components/*/react/index.d.ts"
    },
    "./tokens/css/dark.css": "./dist/tokens/bundle-dark.css",
    "./tokens/css/light.css": "./dist/tokens/bundle-light.css",
    "./theme/fonts.css": "./dist/theme/fonts.css"
  },
  "files": [
    "dist",
    "fonts/",
    "theme/fonts.css"
  ],
  "scripts": {
    "clean": "rm -rf dist coverage",
    "compile": "tsc",
    "copy:fonts": "cpy \"public/fonts/*.{woff,woff2}\" \"dist/fonts\"",
    "copy:fonts-css": "cpy \"theme/fonts.css\" \"dist/\"",
    "build:tokens": "tsx scripts/build-css-tokens.ts --verbose",
    "make:figma-mirror": "tsx scripts/make-figma-mirror.ts",
    "build:figma": "npm run build && npm run make:figma-mirror",
    "build": "npm run compile && npm run build:tokens && npm run copy:fonts-css && npm run copy:fonts",
    "lint": "run-p lint:*",
    "lint:eslint": "eslint . --cache --cache-location .cache/eslint",
    "lint:prettier": "prettier . --check --ignore-unknown",
    "format": "run-s format:eslint format:prettier",
    "format:eslint": "eslint . --fix --cache --cache-location .cache/eslint",
    "format:prettier": "prettier . --write --ignore-unknown",
    "prettier:check": "prettier . --check --ignore-unknown",
    "prettier:fix": "prettier . --write --ignore-unknown",
    "storybook": "npm run compile && storybook dev -p 6006",
    "build-storybook": "npm run compile && storybook build",
    "pull": "dotenv -- tokensstudio pull",
    "setup": "dotenv -- tokensstudio setup",
    "release": "npm run build && changeset publish",
    "version": "changeset version && npm i",
    "prepare": "npm run build",
    "chromatic": "npx chromatic --project-token=chpt_1f44909924e5c27",
    "chromatic-deploy": "npx chromatic --project-token=chpt_1f44909924e5c27 --only-storybook",
    "analyze:sizes": "node scripts/analyze-sizes.js",
    "test": "web-test-runner --config web-test-runner.config.mjs --group default",
    "test:watch": "web-test-runner --watch --config web-test-runner.config.mjs --group default",
    "test:coverage": "web-test-runner --coverage --config web-test-runner.config.mjs --group default",
    "test:component": "web-test-runner --watch --config web-test-runner.config.mjs --group",
    "spellcheck": "npx cspell .",
    "verify": "npm run lint && npm run test",
    "test-one": "npm run test components/link/*.test.ts",
    "test-utils": "npm run test utils/internal/test/form-control-base.tests.ts"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.12",
    "@lit/react": "^1.0.8",
    "@shoelace-style/animations": "^1.2.0",
    "@shoelace-style/localize": "^3.2.1",
    "colorjs.io": "^0.5.2",
    "composed-offset-position": "^0.0.6",
    "ibantools": "^4.5.1",
    "lit": "^3.2.1",
    "luxon": "^3.7.2",
    "qr-creator": "^1.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@eslint/js": "^9.22.0",
    "@open-wc/testing": "^4.0.0",
    "@storybook/addon-a11y": "^10.2.10",
    "@storybook/addon-docs": "^10.2.10",
    "@storybook/addon-themes": "^10.2.10",
    "@storybook/builder-vite": "^10.2.10",
    "@storybook/react": "^10.2.10",
    "@storybook/web-components": "^10.2.10",
    "@storybook/web-components-vite": "^10.2.10",
    "@tokens-studio/sd-transforms": "^2.0.3",
    "@tokens-studio/sdk": "^2.2.2",
    "@tokens-studio/types": "^0.5.2",
    "@types/luxon": "^3.7.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.16.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@web/dev-server-esbuild": "^1.0.4",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-commands": "^0.9.0",
    "@web/test-runner-coverage-v8": "^0.8.0",
    "@web/test-runner-playwright": "^0.11.1",
    "chai": "^5.1.2",
    "chromatic": "^15.1.1",
    "concurrently": "^9.1.2",
    "cpy": "^11.1.0",
    "cpy-cli": "^5.0.0",
    "cspell": "^9.2.1",
    "dotenv-cli": "^8.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-chai-friendly": "^1.1.0",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-lit-a11y": "^5.1.1",
    "eslint-plugin-mocha": "^10.5.0",
    "eslint-plugin-storybook": "^0.1.1",
    "eslint-plugin-wc": "^3.1.0",
    "filesize": "^9.0.11",
    "glob": "^13.0.0",
    "globals": "^15.13.0",
    "globby": "^14.1.0",
    "http-server": "^14.1.1",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-reports": "^3.2.0",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.54.2",
    "prettier": "^3.3.3",
    "sinon": "^21.0.0",
    "storybook": "^10.2.10",
    "style-dictionary": "^5.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.0"
  },
  "keywords": [
    "design-system",
    "web-components"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "customElements": "custom-elements.json",
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
